{
  "manifest_version": 3,
  "name": "VRCVideoCacher Cookies Exporter",
  "description": "Exports cookies to VRCVideoCacher",
  "version": "2.0.0",
  "permissions": ["cookies"],
  "host_permissions": ["*://*.youtube.com/*", "http://127.0.0.1:9696/*"],
  "key": "",
  "author": "clienthax@gmail.com",
  "minimum_chrome_version": "88",
  "background": {
    "service_worker": "background.mjs",
    "scripts": ["background.mjs"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
